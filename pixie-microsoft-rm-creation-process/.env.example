# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare (required for Part 1 + DNS)
CLOUDFLARE_API_TOKEN=your-cf-token
CLOUDFLARE_ACCOUNT_ID=your-cf-account-id
CLOUDFLARE_GLOBAL_KEY=your-cf-global-key
CLOUDFLARE_EMAIL=your-cf-email

# Dynadot (required for purchased domains)
DYNADOT_API_KEY=your-dynadot-key

# Recovery worker
INSTANTLY_RECOVERY_API_KEY=your-instantly-recovery-api-key
RECOVERY_MAILBOX_PASSWORD=your-recovery-mailbox-password
CRON_SECRET=your-shared-cron-secret
PIXIE_APP_API_BASE_URL=https://api.simpleinboxes.com/api/v1
