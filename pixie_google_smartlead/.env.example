# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare (required)
CLOUDFLARE_API_TOKEN=your-cf-token
CLOUDFLARE_ACCOUNT_ID=your-cf-account-id

# Dynadot (required for purchased domains)
DYNADOT_API_KEY=your-dynadot-key

# PartnerHub (required for Google provisioning)
PARTNERHUB_API_BASE_URL=https://partnerhubapi.netstager.com/api
PARTNERHUB_API_KEY=your-partnerhub-jwt
PARTNERHUB_PLAN_ID=your-plan-id

# 1Password (required for credential storage)
OP_SERVICE_ACCOUNT_TOKEN=ops_eyJ...
ONEPASSWORD_VAULT=your-vault-id

# Worker configuration
GOOGLE_WORKER_ACTION_TYPES=google_provision
GOOGLE_LIFECYCLE_ACTION_TYPES=google_add_inboxes,google_remove_inboxes,google_update_inboxes,google_update_profile_photos
GOOGLE_PLAYWRIGHT_HEADLESS=true
GOOGLE_REQUIRE_MFA_ENROLLMENT=true
GOOGLE_MFA_NON_HEADLESS_FALLBACK=true
GOOGLE_MFA_NON_HEADLESS_MAX_ATTEMPTS=1
GOOGLE_WORKER_MAX_RETRIES=12
GOOGLE_ADMIN_APPS_ATTEMPTS=3
GOOGLE_ADMIN_APPS_RETRY_DELAY_SECONDS=20
SMARTLEAD_ENABLE_PRIVATE_VALIDATION_FALLBACK=true

# Free/nonprofit Google worker configuration
# The production compose starts this as pixie-google-free-nonprofit-worker.
NONPROFIT_GOOGLE_ACTION_TYPES=free_google_provision,free_google_cancel_domain
NONPROFIT_GOOGLE_POLL_SECONDS=10
NONPROFIT_GOOGLE_PLAYWRIGHT_HEADLESS=true
NONPROFIT_GOOGLE_REQUIRE_MFA_ENROLLMENT=true
NONPROFIT_GOOGLE_ADMIN_OP_VAULT=your-nonprofit-admin-vault-id
NONPROFIT_GOOGLE_USER_OP_VAULT=icje7jpscrdm6xtlcr252zxinq
